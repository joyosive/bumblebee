# XRPL Network
XRPL_NETWORK=testnet
XRPL_WSS=wss://s.altnet.rippletest.net:51233

# Bee Wallets (fund each from https://faucet.altnet.rippletest.net)
TREASURY_WALLET_SEED=your_treasury_seed
FACILITATOR_WALLET_SEED=your_facilitator_seed
EVALUATOR_WALLET_SEED=your_evaluator_seed
VERIFIER_WALLET_SEED=your_verifier_seed
REVIEWER_WALLET_SEED=your_reviewer_seed

# NGO Test Wallet (receives milestone payments)
NGO_WALLET_SEED=your_ngo_seed

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# LLM — Groq is primary (free), Gemini is fallback
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GOOGLE_API_KEYS=key1,key2
GOOGLE_MODEL=gemini-2.0-flash

# RLUSD Stablecoin (optional — enables dual-currency XRP + USD)
# Testnet issuer: https://docs.ripple.com/products/stablecoin/developer-resources/rlusd-on-the-xrpl
RLUSD_ISSUER=rQhWct2fv4Vc4KRjRgMrxa8xPN9Zx9iLKV

# MCP Server (path to mcp-xrpl submodule)
MCP_SERVER_PATH=./mcp-xrpl/mcp-server

# Dashboard Bridge
DASHBOARD_WS_URL=ws://localhost:3001
