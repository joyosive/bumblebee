# XRPL Network
XRPL_NETWORK=testnet
XRPL_WSS=wss://s.altnet.rippletest.net:51233

# Treasury Wallet (fund from https://faucet.altnet.rippletest.net)
TREASURY_WALLET_SEED=your_treasury_seed_here

# Agent Wallets (get from testnet faucet)
SCOUT_WALLET_SEED=your_scout_seed_here
ANALYST_WALLET_SEED=your_analyst_seed_here
FUNDER_WALLET_SEED=your_funder_seed_here

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# LLM (Google Gemini)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_MODEL=gemini-2.0-flash

# Dashboard WebSocket
DASHBOARD_WS_URL=ws://localhost:3001

# MCP Server (path to mcp-xrpl server, optional)
MCP_SERVER_PATH=./mcp-xrpl
